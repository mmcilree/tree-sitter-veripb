; =========================================================================
; XPB (VeriPB-extended OPB) syntax highlights
; =========================================================================

; -------------------------------------------------------------------------
; Comments
; -------------------------------------------------------------------------

(comment) @comment

; -------------------------------------------------------------------------
; Directives and objective keywords
; -------------------------------------------------------------------------

"preserved" @keyword.function

[
  "min"
  "max"
] @keyword.function

; -------------------------------------------------------------------------
; Operators
; -------------------------------------------------------------------------

(relational_operator) @operator
(xpb_relational_operator) @operator

[
  "~"
  "==>"
  "<=="
] @operator

; -------------------------------------------------------------------------
; Numbers and identifiers
; -------------------------------------------------------------------------

(signed_integer) @number

(variable (identifier) @variable)

(label) @label

; -------------------------------------------------------------------------
; Punctuation
; -------------------------------------------------------------------------

[
  ";"
  ":"
] @punctuation.delimiter
